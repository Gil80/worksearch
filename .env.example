# Trigger.dev
# Get your secret key from: cloud.trigger.dev → your project → API Keys
TRIGGER_SECRET_KEY=

# GotFriends Job Scraper - Google Sheets Configuration
# Create a free Google Cloud project and service account to get these values:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project
# 3. Enable Google Sheets API
# 4. Create a Service Account → download JSON key
# 5. Share your Google Sheet with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GOOGLE_SHEET_ID=1a2b3c4d5e6f7g8h9i0j (the ID from your Google Sheet URL)
